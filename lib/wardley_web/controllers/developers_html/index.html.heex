<Layouts.app
  flash={@flash}
  current_scope={@current_scope}
  container_class="mx-auto max-w-6xl space-y-8"
>
  <section class="space-y-3 max-w-3xl">
    <h1 class="text-3xl font-bold text-slate-950 dark:text-slate-100">
      Wardley.app API
    </h1>
    <p class="text-lg leading-8 text-slate-700 dark:text-slate-300">
      Read and edit Wardley maps over HTTP.
    </p>
  </section>

  <section class="grid gap-4 md:grid-cols-3">
    <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-base font-semibold text-slate-950 dark:text-slate-100">
        API token
      </h2>
      <p class="mt-3 text-sm leading-6 text-slate-700 dark:text-slate-300">
        Sign in with GitHub, open Settings, then generate a 30-day token.
      </p>
    </article>
    <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-base font-semibold text-slate-950 dark:text-slate-100">
        Live updates
      </h2>
      <p class="mt-3 text-sm leading-6 text-slate-700 dark:text-slate-300">
        API mutations broadcast to the browser editor in real time.
      </p>
    </article>
    <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-base font-semibold text-slate-950 dark:text-slate-100">
        JSON + Bearer
      </h2>
      <p class="mt-3 text-sm leading-6 text-slate-700 dark:text-slate-300">
        All write requests use
        <code class="font-mono text-xs">content-type: application/json</code>
        and <code class="font-mono text-xs">Authorization: Bearer</code>.
      </p>
    </article>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div>
        <h2 class="text-xl font-semibold text-slate-950 dark:text-slate-100">
          Endpoints
        </h2>
      </div>
      <a
        href={~p"/llms.txt"}
        class="inline-flex items-center justify-center rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        llms.txt
      </a>
    </div>

    <div class="mt-6 overflow-x-auto">
      <table
        id="api-routes"
        class="min-w-full divide-y divide-slate-200 text-left text-sm dark:divide-slate-800"
      >
        <thead>
          <tr class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">
            <th class="py-3 pr-4 font-semibold">Method</th>
            <th class="py-3 pr-4 font-semibold">Path</th>
            <th class="py-3 pr-4 font-semibold">Purpose</th>
            <th class="py-3 font-semibold">Auth</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
          <tr :for={route <- @api_routes}>
            <td class="py-4 pr-4 align-top">
              <span class={[
                "inline-flex rounded px-2 py-1 font-mono text-xs font-bold",
                route.verb == "GET" &&
                  "bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-200",
                route.verb == "POST" &&
                  "bg-emerald-50 text-emerald-700 dark:bg-emerald-950 dark:text-emerald-200",
                route.verb == "PATCH" &&
                  "bg-amber-50 text-amber-700 dark:bg-amber-950 dark:text-amber-200",
                route.verb == "DELETE" &&
                  "bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-200"
              ]}>
                {route.verb}
              </span>
            </td>
            <td class="py-4 pr-4 align-top">
              <code class="whitespace-nowrap rounded bg-slate-100 px-2 py-1 font-mono text-xs text-slate-800 dark:bg-slate-950 dark:text-slate-100">
                {route.path}
              </code>
            </td>
            <td class="max-w-md py-4 pr-4 align-top">
              <p class="font-medium text-slate-950 dark:text-slate-100">{route.name}</p>
              <p class="mt-1 leading-6 text-slate-600 dark:text-slate-300">{route.description}</p>
            </td>
            <td class="py-4 align-top text-slate-700 dark:text-slate-300">
              {route.auth}
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-xl font-semibold text-slate-950 dark:text-slate-100">
        Token Flow
      </h2>
      <ol class="mt-4 list-decimal space-y-2 pl-5 text-sm leading-6 text-slate-700 dark:text-slate-300">
        <li>Open <code class="font-mono">/login</code> and sign in with GitHub.</li>
        <li>Open <code class="font-mono">/users/settings</code>.</li>
        <li>Generate a token in the API token panel and copy it immediately.</li>
        <li>
          Send it as <code class="font-mono">Authorization: Bearer $WARDLEY_API_TOKEN</code>.
        </li>
      </ol>
    </article>

    <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <h2 class="text-xl font-semibold text-slate-950 dark:text-slate-100">
        Coordinates
      </h2>
      <dl class="mt-4 space-y-3 text-sm leading-6 text-slate-700 dark:text-slate-300">
        <div>
          <dt class="font-semibold text-slate-950 dark:text-slate-100">x_pct</dt>
          <dd>Evolution from 0 genesis to 100 commodity.</dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-950 dark:text-slate-100">y_pct</dt>
          <dd>Visibility from 0 most visible to 100 least visible.</dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-950 dark:text-slate-100">DSL</dt>
          <dd>
            OWM DSL uses <code class="font-mono">[visibility, evolution]</code> from 0.0 to 1.0.
          </dd>
        </div>
      </dl>
    </article>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
    <h2 class="text-xl font-semibold text-slate-950 dark:text-slate-100">
      Examples
    </h2>
    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      <pre
        phx-no-curly-interpolation
        class="overflow-x-auto rounded-md bg-slate-950 p-4 text-xs leading-6 text-slate-100"
      ><code>curl -H "Authorization: Bearer $WARDLEY_API_TOKEN" \
  http://localhost:4000/api/map</code></pre>

      <pre
        phx-no-curly-interpolation
        class="overflow-x-auto rounded-md bg-slate-950 p-4 text-xs leading-6 text-slate-100"
      ><code>curl -X POST http://localhost:4000/api/nodes \
  -H "Authorization: Bearer $WARDLEY_API_TOKEN" \
  -H "content-type: application/json" \
  -d '{"map_id":1,"text":"API","x_pct":55,"y_pct":45}'</code></pre>
    </div>
  </section>
</Layouts.app>
